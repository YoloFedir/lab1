import tkinter as tk
from tkinter import filedialog, messagebox
from PIL import Image, ImageTk


class LFSR:
    def __init__(self, seed: int, bits: int = 32, taps=(31, 21, 1, 0)):
        if seed == 0:
            raise ValueError("Seed не може бути 0.")
        self.bits = bits
        self.mask = (1 << bits) - 1
        self.state = seed & self.mask
        self.taps = taps

    def next_bit(self) -> int:
        new_bit = 0
        for t in self.taps:
            new_bit ^= (self.state >> t) & 1

        out_bit = self.state & 1
        self.state = ((self.state >> 1) | (new_bit << (self.bits - 1))) & self.mask
        return out_bit

    def next_byte(self) -> int:
        value = 0
        for i in range(8):
            value |= (self.next_bit() << i)
        return value


def xor_encrypt_image(img: Image.Image, seed: int) -> Image.Image:
    img = img.convert("RGB")
    data = bytearray(img.tobytes())

    lfsr = LFSR(seed=seed)

    for i in range(len(data)):
        data[i] ^= lfsr.next_byte()

    encrypted = Image.frombytes("RGB", img.size, bytes(data))
    return encrypted


def xor_decrypt_image(img: Image.Image, seed: int) -> Image.Image:
    # XOR-шифр симетричний: розшифрування = те саме XOR ще раз
    return xor_encrypt_image(img, seed)


class ImageCipherApp:
    def __init__(self, root):
        self.root = root
        self.root.title("XOR-шифрування зображень")
        self.root.geometry("1400x760")
        self.root.configure(bg="#f0f0f0")

        self.encrypt_input_image = None
        self.encrypt_output_image = None
        self.decrypt_input_image = None
        self.decrypt_output_image = None

        self.encrypt_input_preview = None
        self.encrypt_output_preview = None
        self.decrypt_input_preview = None
        self.decrypt_output_preview = None

        self.build_ui()

    def build_ui(self):
        title = tk.Label(
            self.root,
            text="XOR-шифрування зображень псевдовипадковим потоком",
            font=("Arial", 18, "bold"),
            bg="#f0f0f0"
        )
        title.pack(pady=10)

        info = tk.Label(
            self.root,
            text="Для правильного розшифрування потрібно ввести той самий seed.",
            font=("Arial", 11),
            bg="#f0f0f0"
        )
        info.pack(pady=3)

        main_frame = tk.Frame(self.root, bg="#f0f0f0")
        main_frame.pack(fill="both", expand=True, padx=10, pady=10)

        left_frame = tk.LabelFrame(main_frame, text="Шифрування", font=("Arial", 12, "bold"), padx=10, pady=10)
        left_frame.pack(side="left", fill="both", expand=True, padx=5)

        right_frame = tk.LabelFrame(main_frame, text="Розшифрування", font=("Arial", 12, "bold"), padx=10, pady=10)
        right_frame.pack(side="right", fill="both", expand=True, padx=5)

        self.build_encrypt_panel(left_frame)
        self.build_decrypt_panel(right_frame)

    def build_encrypt_panel(self, parent):
        controls = tk.Frame(parent)
        controls.pack(fill="x", pady=5)

        tk.Button(controls, text="Вибрати зображення", command=self.load_encrypt_image, width=20).grid(row=0, column=0, padx=5, pady=5)

        tk.Label(controls, text="Seed:").grid(row=0, column=1, padx=5)
        self.enc_seed_entry = tk.Entry(controls, width=15)
        self.enc_seed_entry.grid(row=0, column=2, padx=5)
        self.enc_seed_entry.insert(0, "123456")

        tk.Button(controls, text="Зашифрувати", command=self.encrypt_action, width=15).grid(row=0, column=3, padx=5)
        tk.Button(controls, text="Зберегти", command=self.save_encrypted_image, width=15).grid(row=0, column=4, padx=5)

        previews = tk.Frame(parent)
        previews.pack(fill="both", expand=True, pady=10)

        input_frame = tk.LabelFrame(previews, text="Оригінал", padx=10, pady=10)
        input_frame.pack(side="left", fill="both", expand=True, padx=5)

        output_frame = tk.LabelFrame(previews, text="Зашифроване зображення", padx=10, pady=10)
        output_frame.pack(side="right", fill="both", expand=True, padx=5)

        self.enc_input_label = tk.Label(input_frame, text="Немає зображення")
        self.enc_input_label.pack(expand=True)

        self.enc_output_label = tk.Label(output_frame, text="Немає результату")
        self.enc_output_label.pack(expand=True)

    def build_decrypt_panel(self, parent):
        controls = tk.Frame(parent)
        controls.pack(fill="x", pady=5)

        tk.Button(controls, text="Вибрати зображення", command=self.load_decrypt_image, width=20).grid(row=0, column=0, padx=5, pady=5)

        tk.Label(controls, text="Seed:").grid(row=0, column=1, padx=5)
        self.dec_seed_entry = tk.Entry(controls, width=15)
        self.dec_seed_entry.grid(row=0, column=2, padx=5)
        self.dec_seed_entry.insert(0, "123456")

        tk.Button(controls, text="Розшифрувати", command=self.decrypt_action, width=15).grid(row=0, column=3, padx=5)
        tk.Button(controls, text="Зберегти", command=self.save_decrypted_image, width=15).grid(row=0, column=4, padx=5)

        previews = tk.Frame(parent)
        previews.pack(fill="both", expand=True, pady=10)

        input_frame = tk.LabelFrame(previews, text="Зашифроване", padx=10, pady=10)
        input_frame.pack(side="left", fill="both", expand=True, padx=5)

        output_frame = tk.LabelFrame(previews, text="Розшифроване зображення", padx=10, pady=10)
        output_frame.pack(side="right", fill="both", expand=True, padx=5)

        self.dec_input_label = tk.Label(input_frame, text="Немає зображення")
        self.dec_input_label.pack(expand=True)

        self.dec_output_label = tk.Label(output_frame, text="Немає результату")
        self.dec_output_label.pack(expand=True)

    def create_preview(self, img, max_size=(500, 500)):
        preview = img.copy()
        preview.thumbnail(max_size)
        return ImageTk.PhotoImage(preview)

    def load_encrypt_image(self):
        path = filedialog.askopenfilename(
            title="Виберіть зображення",
            filetypes=[("Image files", "*.png *.jpg *.jpeg *.bmp *.webp")]
        )
        if not path:
            return

        try:
            self.encrypt_input_image = Image.open(path).convert("RGB")
            self.encrypt_input_preview = self.create_preview(self.encrypt_input_image)
            self.enc_input_label.config(image=self.encrypt_input_preview, text="")
            self.enc_output_label.config(image="", text="Немає результату")
            self.encrypt_output_image = None
        except Exception as e:
            messagebox.showerror("Помилка", f"Не вдалося відкрити зображення:\n{e}")

    def load_decrypt_image(self):
        path = filedialog.askopenfilename(
            title="Виберіть зображення",
            filetypes=[("Image files", "*.png *.jpg *.jpeg *.bmp *.webp")]
        )
        if not path:
            return

        try:
            self.decrypt_input_image = Image.open(path).convert("RGB")
            self.decrypt_input_preview = self.create_preview(self.decrypt_input_image)
            self.dec_input_label.config(image=self.decrypt_input_preview, text="")
            self.dec_output_label.config(image="", text="Немає результату")
            self.decrypt_output_image = None
        except Exception as e:
            messagebox.showerror("Помилка", f"Не вдалося відкрити зображення:\n{e}")

    def encrypt_action(self):
        if self.encrypt_input_image is None:
            messagebox.showwarning("Увага", "Спочатку виберіть зображення.")
            return

        try:
            seed = int(self.enc_seed_entry.get())
            if seed == 0:
                raise ValueError("Seed не може бути 0.")

            self.encrypt_output_image = xor_encrypt_image(self.encrypt_input_image, seed)
            self.encrypt_output_preview = self.create_preview(self.encrypt_output_image)
            self.enc_output_label.config(image=self.encrypt_output_preview, text="")
        except Exception as e:
            messagebox.showerror("Помилка", f"Не вдалося зашифрувати зображення:\n{e}")

    def decrypt_action(self):
        if self.decrypt_input_image is None:
            messagebox.showwarning("Увага", "Спочатку виберіть зашифроване зображення.")
            return

        try:
            seed = int(self.dec_seed_entry.get())
            if seed == 0:
                raise ValueError("Seed не може бути 0.")

            self.decrypt_output_image = xor_decrypt_image(self.decrypt_input_image, seed)
            self.decrypt_output_preview = self.create_preview(self.decrypt_output_image)
            self.dec_output_label.config(image=self.decrypt_output_preview, text="")
        except Exception as e:
            messagebox.showerror("Помилка", f"Не вдалося розшифрувати зображення:\n{e}")

    def save_encrypted_image(self):
        if self.encrypt_output_image is None:
            messagebox.showwarning("Увага", "Немає зашифрованого зображення для збереження.")
            return

        path = filedialog.asksaveasfilename(
            title="Зберегти зашифроване зображення",
            defaultextension=".png",
            filetypes=[("PNG", "*.png"), ("BMP", "*.bmp")]
        )
        if not path:
            return

        try:
            self.encrypt_output_image.save(path)
            messagebox.showinfo("Успіх", "Зашифроване зображення збережено.")
        except Exception as e:
            messagebox.showerror("Помилка", f"Не вдалося зберегти файл:\n{e}")

    def save_decrypted_image(self):
        if self.decrypt_output_image is None:
            messagebox.showwarning("Увага", "Немає розшифрованого зображення для збереження.")
            return

        path = filedialog.asksaveasfilename(
            title="Зберегти розшифроване зображення",
            defaultextension=".png",
            filetypes=[("PNG", "*.png"), ("BMP", "*.bmp")]
        )
        if not path:
            return

        try:
            self.decrypt_output_image.save(path)
            messagebox.showinfo("Успіх", "Розшифроване зображення збережено.")
        except Exception as e:
            messagebox.showerror("Помилка", f"Не вдалося зберегти файл:\n{e}")


if __name__ == "__main__":
    root = tk.Tk()
    app = ImageCipherApp(root)
    root.mainloop()